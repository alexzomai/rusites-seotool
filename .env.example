# Domain
DOMAIN=example.com

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=db

# Parser
BASE_URL=https://www.liveinternet.ru/rating/ru/today.tsv
PARAM_PER_PAGE=per_page
PARAM_PAGE=page
PER_PAGE=1000
# Internal URL of the backend container (used by parser to upload CSV)
BACKEND_URL=http://backend:8000

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:change_me@database:5432/db
# Dev only: comma-separated extra CORS origins, e.g. http://localhost:3000
# CORS_ORIGINS=["http://localhost:3000"]
