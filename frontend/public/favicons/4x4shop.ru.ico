<script type="text/javascript">

function getEvent(func){
	$('eventAjax').setStyle('display', 'block');
	showEventBlock(func);
	var url = 'index.php?option=com_mus&view=registration&task=getEventBlock&format=row';
	var req = new Request({
		method: 'post',
		url: url,
		evalScripts: true,
		onComplete: function(response) {
			$('eventContent').set('html', response);
			$('closeBlock').setStyle('display', 'block');
			$('black_fon').setStyle('display', 'block');
			//Asset.javascript('/media/system/js/validate.js');
			$('eventAjax').setStyle('display', 'none');
		}
	}).send('bbb07fc250135799ab1a54eec454d28d=1&event='+(func));
}
$('closeBlock').addEvent('click', function () {
	hideEventBlock();
});
$('black_fon').addEvent('click', function () {
	hideEventBlock();
});
	
var eventBlock = $('eventBlock');
eventBlock.set('morph', {
	duration: 500
});
function showEventBlock(func){
	if (func == 'login') {
		eventBlock.morph({
			'opacity': 1,
			'top': 80,
			'left': 300,
			'width': 600,
			'height': 300
		});
	} else if (func == 'registration') {
		eventBlock.morph({
			'opacity': 1,
			'top': 0,
			'left': 300,
			'width': 600,
			'height': 600
		});
	} else if (func == 'reset') {
		eventBlock.morph({
			'opacity': 1,
			'top': 40,
			'left': 300,
			'width': 600,
			'height': 520
		});
	}
}
function hideEventBlock(){
	if ($('regForm')) {
		var req = new Request({
			method: 'post',
			url: 'index.php?option=com_mus&view=registration&task=hideRegUser&format=row'
		}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+$('email').get('value')+'&password1='+$('password1').get('value')+'&password2='+$('password2').get('value')+'&name='+$('name').get('value')+'&phone='+$('phone').get('value')+'&address='+$('address').get('value'));
	}
	eventBlock.morph({
		'opacity': 0.2,
		'margin': 0,
		'top': -60,
		'left': 1000,
		'width': 0,
		'height': 0
	});
	$('closeBlock').setStyle('display', 'none');
	$('black_fon').setStyle('display', 'none');
	jQuery('#setProductBasketInfo').hide()
	if ($('regComplete')) top.location.reload();
}
function emailValidateFree(fun){
	var email = $('email').get('value');
	var r = /.+@.+\..+/i
	if (!r.test(email)) {
		$('email').addClass('invalid');
		$('email').set('title', 'Введите корректный адрес электронной почты!');
		$('emaildesc').set('html', '<b style="color:RED">Введите корректный адрес электронной почты!</b>');
		//console.log('email false');
	} else {
		$('eventAjax').setStyle('display', 'block');
		var url = 'index.php?option=com_mus&view=registration&task=emailValidateFree&format=row';
		var req = new Request({
			method: 'post',
			url: url,
			onComplete: function(response) {
				if (response.replace(/\s+/g,'') == 'free') {
					$('email').removeClass('invalid');
					$('email').set('title', '');
					$('emaildesc').set('html', '<b style="color:GREEN">Email указан правильно</b>');
					//console.log('email true');
					if (fun == 'regUser') {
						regUser(email);
					} else if (fun == 'pinRepeat') {
						pinRepeat(email);
					}
				} else {
					$('email').addClass('invalid');
					$('email').set('title', 'Ошибка!!! Этот Email уже заят! Попробуйте восстановить пароль или введите другой Email.');
					$('emaildesc').set('html', '<b style="color:RED">Ошибка!!! Этот Email уже заят!<br/>Попробуйте восстановить пароль или введите другой Email.</b>');
					//console.log('email busy');
				}
				$('eventAjax').setStyle('display', 'none');
			}
		}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+email);
	}
}
function buttonValidate(){
	var email = $('email').get('value');
	var password1 = $('password1').get('value');
	var password2 = $('password2').get('value');
	var validatePassword = $$('.validate-password');
	var passwordDesc = $$('.passworddesc');
	var required = $$('.required');
	var reqdesc = $$('.reqdesc');
	required.each(function (req, i) {
		if (req.get('value') == '') {
			req.addClass('invalid');
			req.set('title', 'Пожалуйста, заполните это поле!');
			reqdesc[i].setStyle('color', 'RED');
		} else {
			req.removeClass('invalid');
			req.set('title', '');
			reqdesc[i].setStyle('color', '#7c7c7c');
		}
	});
	if (password1 != password2) {
		validatePassword.each(function (password, i) {
			password.addClass('invalid');
			password.set('title', 'Пароли не совпадают!');
			passwordDesc[i].set('html', '<b style="color:RED">Пароли не совпадают!</b>');
		});
	} else if (password1.length < 4 || password2.length < 4) {
		validatePassword.each(function (password, i) {
			password.addClass('invalid');
			password.set('title', 'Введите пароль не менее 4-х символов!');
			passwordDesc[i].set('html', '<b style="color:RED">Введите пароль не менее 4-х символов!</b>');
		});
	} else {
		validatePassword.each(function (password, i) {
			password.removeClass('invalid');
			password.set('title', '');
			passwordDesc[i].set('html', '<b style="color:GREEN">Пароль указан правильно</b>');
		});
	}
	if ($('privacy').checked) {
		$('privacy').removeClass('invalid');
		$('privacyDesc').setStyle('color', '#7c7c7c');
	} else {
		$('privacy').addClass('invalid');
		$('privacyDesc').setStyle('color', 'RED');
	}
	var invalidForm = $$('#regForm .invalid');
	if (invalidForm.length == 0) {
		emailValidateFree('regUser');
	}
}
function regUser(email){
	$('eventAjax').setStyle('display', 'block');
	var url = 'index.php?option=com_mus&view=registration&task=regUser&format=row';
	var req = new Request({
		method: 'post',
		url: url,
		onComplete: function(response) {
			$('eventContent').set('html', response);
			$('eventAjax').setStyle('display', 'none');
		}
	}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+email+'&password='+$('password1').get('value')+'&name='+$('name').get('value')+'&phone='+$('phone').get('value')+'&address='+$('address').get('value'));
}
function pinRepeat(email){
	$('eventAjax').setStyle('display', 'block');
	var url = 'index.php?option=com_mus&view=registration&task=pinRepeat&format=row';
	var req = new Request({
		method: 'post',
		url: url,
		onComplete: function(response) {
			$('eventContent').set('html', response);
			$('eventAjax').setStyle('display', 'none');
		}
	}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+email);
}
function regComplete(){
	var pin = $('pin').get('value');
	if (pin.length == 4) {
		$('eventAjax').setStyle('display', 'block');
		var url = 'index.php?option=com_mus&view=registration&task=regComplete&format=row';
		var req = new Request({
			method: 'post',
			url: url,
			onComplete: function(response) {
				$('eventContent').set('html', response);
				$('eventAjax').setStyle('display', 'none');
			}
		}).send('bbb07fc250135799ab1a54eec454d28d=1&pin='+pin);
	}
}
function resetPassword(){
	var email = $('email').get('value');
	var r = /.+@.+\..+/i
	if (!r.test(email)) {
		$('email').addClass('invalid');
		$('email').set('title', 'Введите корректный адрес электронной почты!');
		$('emaildesc').set('html', '<b style="color:RED">Введите корректный адрес электронной почты!</b>');
	} else {
		$('eventAjax').setStyle('display', 'block');
		var url = 'index.php?option=com_mus&view=registration&task=emailValidateFree&format=row';
		var req = new Request({
			method: 'post',
			url: url,
			onComplete: function(response) {
				if (response.replace(/\s+/g,'') == 'busy') {
					$('email').removeClass('invalid');
					$('email').set('title', '');
					password(email);
				} else {
					$('email').addClass('invalid');
					$('email').set('title', 'Ошибка!!! Учетная запись с таким Email не найдена. Зарегистрируйтесь на сайте чтобы войти.');
					$('emaildesc').set('html', '<b style="color:RED">Ошибка!!! Учетная запись с таким Email не найдена.<br/>Зарегистрируйтесь на сайте чтобы войти.</b>');
				}
				$('eventAjax').setStyle('display', 'none');
			}
		}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+email);
	}
}
function password(email){
	$('eventAjax').setStyle('display', 'block');
	var url = 'index.php?option=com_mus&view=registration&task=resetPassword&format=row';
	var req = new Request({
		method: 'post',
		url: url,
		onComplete: function(response) {
			$('eventContent').set('html', response);
			$('eventAjax').setStyle('display', 'none');
		}
	}).send('bbb07fc250135799ab1a54eec454d28d=1&email='+email);
}
			
window.addEvent('domready', function () {
		$('block-catalog').addEvent("mouseenter", function (e) {
		$('catalog').setStyle('background-position-y', '5px');
		$('catalog').getElements('div.title').setStyle('color', '#e15616');
	});
	$('block-catalog').addEvent("mouseleave", function (e) {
		$('list-catalog').setStyle('display', 'none');
		$('catalog').setStyle('background-position-y', '-90px');
		$('catalog').getElements('div.title').setStyle('color', '#666666');
	});
		$('block-catalog').addEvent("click", function (e) {
		$('list-catalog').setStyle('display', 'block');
	});
	var images = $$('.image');		
	images.each(function (img, i) {	
		var scrollImg = new Scroller(img, {
			area: 100,
			velocity: 0.1
		});
		scrollImg.start();	
	});
});
</script>
