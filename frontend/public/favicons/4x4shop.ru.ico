var params = new URLSearchParams(window.location.search);
var box1 = params.get('orderid');
var box2 = params.get('price');
box2 =  (Number(box2)/100).toLocaleString();
jQuery('p.order-number').html('<b>Номер заказа:</b> № ' + box1);
jQuery('p.order-price').html('<b>Сумма заказа:</b> ' + box2 + ' Р ');
