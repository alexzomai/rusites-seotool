                <div id="cookie-banner" style="display:none;" class="cookie-banner">
                    <div class="cookie-banner__content">
    <span>
      Нажимая кнопку "Принять" или продолжая пользоваться сайтом, вы соглашаетесь на обработку файлов cookies. Подробнее вы можете узнать в Политике использования cookies
      <a href="/cookies.html" target="_blank">Подробнее о cookies</a>.
    </span>
                        <button id="cookie-ok" class="cookie-banner__btn">Принять</button>
                    </div>
                </div>

                <style>
                    .cookie-banner {
                        position: fixed;
                        bottom: 0;
                        left: 0;
                        right: 0;
                        background: #2b2b2b;
                        color: #fff;
                        padding: 15px;
                        font-size: 14px;
                        z-index: 9999;
                        box-shadow: 0 -2px 5px rgba(0,0,0,0.2);
                    }

                    .cookie-banner__content {
                        max-width: 960px;
                        margin: 0 auto;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        flex-wrap: wrap;
                    }

                    .cookie-banner__content a {
                        color: #80c0ff;
                        text-decoration: underline;
                        margin-left: 5px;
                    }

                    .cookie-banner__btn {
                        background: #4caf50;
                        color: white;
                        border: none;
                        padding: 8px 14px;
                        border-radius: 4px;
                        cursor: pointer;
                        font-size: 14px;
                    }

                    .cookie-banner__btn:hover {
                        background: #45a043;
                    }
                </style>

                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        const banner = document.getElementById('cookie-banner');
                        const button = document.getElementById('cookie-ok');

                        // Проверка, было ли уже скрытие баннера
                        if (!localStorage.getItem('cookieAccepted')) {
                            banner.style.display = 'block';
                        }

                        button.addEventListener('click', function () {
                            // Устанавливаем метку на 24 часа
                            const expirationTime = Date.now() + 24 * 60 * 60 * 1000;
                            localStorage.setItem('cookieAccepted', expirationTime);
                            banner.style.display = 'none';
                        });

                        // Проверка срока действия
                        const savedTime = localStorage.getItem('cookieAccepted');
                        if (savedTime && Date.now() > parseInt(savedTime, 10)) {
                            localStorage.removeItem('cookieAccepted');
                            banner.style.display = 'block';
                        }
                    });
                </script>

