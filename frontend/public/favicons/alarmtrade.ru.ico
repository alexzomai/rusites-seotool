<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Доступ ограничен</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background: #0b1220;
      color: #e8eefc;
    }
    .wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
    }
    .card {
      width: min(680px, 100%);
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 18px;
      padding: 22px 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.35);
    }
    h1 { margin: 0 0 10px; font-size: 22px; }
    p { margin: 0 0 14px; line-height: 1.5; color: rgba(232,238,252,0.9); }
    .row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 14px; }
    button {
      border: 0;
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 15px;
      cursor: pointer;
    }
    .primary { background: #4f7cff; color: #fff; }
    .secondary { background: rgba(255,255,255,0.12); color: #fff; }
    .hint { font-size: 13px; opacity: 0.75; margin-top: 10px; }
    .small { font-size: 12px; opacity: 0.65; margin-top: 6px; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>Доступ временно ограничен</h1>
      <p>Возможно нужно отключить VPN.</p>

      <div class="row">
        <button class="primary" id="reload">Я отключил VPN</button>
        <button class="secondary" id="retry">Попробовать ещё раз</button>
      </div>

      <div class="hint">Если VPN уже выключен, попробуйте: сменить сеть (Wi-Fi/мобильная) или обновить страницу через Ctrl+F5.</div>
      <div class="small" id="status"></div>
    </div>
  </div>

  <script>
    function reloadNow() {
      // чтобы не застревать в кеше
      const url = new URL(window.location.href);
      url.searchParams.set("_t", Date.now().toString());
      window.location.replace(url.toString());
    }

    document.getElementById("reload").addEventListener("click", reloadNow);
    document.getElementById("retry").addEventListener("click", reloadNow);

    // необязательная авто-попытка каждые 10 секунд
    let secs = 10;
    const statusEl = document.getElementById("status");
    setInterval(() => {
      secs--;
      if (secs <= 0) reloadNow();
      statusEl.textContent = "Автообновление через: " + secs + " сек.";
    }, 1000);
  </script>
</body>
</html>