    <script>
        $(window).scroll(function() {
            if ($(this).scrollTop() > 15) {
                $( ".logotop" ).fadeOut();
            } else {
                $( ".logotop" ).fadeIn();
            }
        });


        $(window).scroll(function(e){
            parallax();
        });
        function parallax(){
            var scrolled = $(window).scrollTop();
            $('.slidex').css('top',-(scrolled*-0.30)+'px');
            $('.top_fol_01f').css('top',-(scrolled*-0.30)+'px');
            $('.top_fol_01z').css('top',-(scrolled*-0.30)+'px');
            $('.top_fol_01a').css('top',-(scrolled*-0.41)+'px');
            $('.top_fol_01e').css('top',-(scrolled*0.20)+'px');
        }
    </script>

