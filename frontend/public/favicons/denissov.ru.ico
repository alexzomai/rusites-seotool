        <style>
            .buttond {
                width: 100%;
                display: block;
                margin: 0em 0 0em 0;
                padding: 1.3em 0em 1.3em 0;
                border: none;
                background: none;
                color: inherit;
                vertical-align: middle;
                position: relative;
                z-index: 1;
                text-align:center;
                -webkit-backface-visibility: hidden;
                -moz-osx-font-smoothing: grayscale;

                cursor:pointer;
            }
            .buttond:focus {
                outline: none;
            }
            .buttond > span {
                vertical-align: middle;
            }
            .sbtn_1{ position:relative; width:100%; height:50px; background:none; margin-top:20px; z-index:200; text-align:center; padding: 0 0px 0 0px;}
            .sbtn_centered{
                position:absolute;
                width:300px;
                left:50%;
                margin-left:-150px;
                padding-top:0px;
                color:#666;
                text-decoration:none;
                font-family: 'Century Gothic';
                font-size:20px;
                letter-spacing:0.06em;
                font-weight:600;
                text-transform:uppercase;
                background:none;
            }
            .buttond--text-thick {
                font-weight: 600;
            }

            /* Borders */
            .buttond--border-thick {
                border: 0px solid;
                border-color: #fff;
                color: #000;
                background:#d48231;
            }
            .button--habra {
                overflow: hidden;
                width:  100%;
                -webkit-transition: border-color 0.3s, color 0.3s;
                transition: border-color 0.3s, color 0.3s;
                -webkit-transition-timing-function: cubic-bezier(0.2, 1, 0.5, 1);
                transition-timing-function: cubic-bezier(0.2, 1, 0.5, 1);
            }
            .button--habra::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 150%;
                height: 100%;
                background: #000;
                z-index: -1;
                -webkit-transform: rotate3d(0, 0, 1, -45deg) translate3d(0, -3em, 0);
                transform: rotate3d(0, 0, 1, -45deg) translate3d(0, -3em, 0);
                -webkit-transform-origin: 0% 100%;
                transform-origin: 0% 100%;
                -webkit-transition: -webkit-transform 0.5s, opacity 0.5s, background-color 0.5s;
                transition: transform 0.5s, opacity 0.5s, background-color 0.5s;
            }
            .button--habra:hover {
                color: #fff;
                border-color: #fff;
            }
            .button--habra.buttond--inverted:hover {
                color: #000;
                border-color: #fff;
                cursor:pointer;
            }
            .button--habra:hover::before {
                opacity: 1;
                background-color: #fff;
                -webkit-transform: rotate3d(0, 0, 1, 0deg);
                transform: rotate3d(0, 0, 1, 0deg);
                -webkit-transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
                transition-timing-function: cubic-bezier(0.2, 1, 0.3, 1);
            }
            .button--habra.buttond--inverted:hover::before {
                background-color: #fff;
            }
            .buttond--text-upper {
                letter-spacing: 0px;
                text-transform: uppercase;
            }
            .buttond--text-thick {
                font-weight: 600;
            }
            .buttond--size-s {
                font-size: 13px;
                font-weight:800;
                font-family: 'Century Gothic';
            }
            #layer_order_sending {
                position:absolute;
                top:110px;
                left:20%;
                width:60%;
                height:80%;
                z-index:6600;
                padding:30px 10px 130px 10px;
                display:none;
                margin-top:0;
