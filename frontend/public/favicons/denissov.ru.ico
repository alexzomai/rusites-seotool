                    $("#menuItems a").parent().eq(e).attr("class","menu-item");
                });
                $(this).parent().attr("class","menu-item_sel");
                return false;
            });

            $(".main-header a").click(function(){
                var down = $($(this).prop("hash")).offset().top;
