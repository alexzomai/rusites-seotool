    <div class="titlus_order">ФОРМА ОБРАТНОЙ СВЯЗИ</div>
    <div id="wrapperx">

        <script type="text/javascript">
            $(document).ready(function(){

                function isValidEmailAddress(emailAddress) {
                    var pattern = /^([a-z\d!#$%&'*+\-\/=?^_`{|}~\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]+(\.[a-z\d!#$%&'*+\-\/=?^_`{|}~\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]+)*|"((([ \t]*\r\n)?[ \t]+)?([\x01-\x08\x0b\x0c\x0e-\x1f\x7f\x21\x23-\x5b\x5d-\x7e\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]|\\[\x01-\x09\x0b\x0c\x0d-\x7f\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]))*(([ \t]*\r\n)?[ \t]+)?")@(([a-z\d\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]|[a-z\d\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF][a-z\d\-._~\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]*[a-z\d\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF])\.)+([a-z\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]|[a-z\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF][a-z\d\-._~\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF]*[a-z\u00A0-\uD7FF\uF900-\uFDCF\uFDF0-\uFFEF])\.?$/i;
                    return pattern.test(emailAddress);
                }

                $("#user_tel_1").keyup(function(){
                    var x = $(this).val().replace(/[^\d\.]/g, '');
                    $(this).val(x);
                });

                $("#user_fio_1").keyup(function(){
                    var x = $(this).val().replace(/[\d\.]/g, '');
                    $(this).val(x);
                });

                $('#btn_submit_1').click(function(){
                    var user_fio_1 	  	= $('#user_fio_1').val();
                    var user_tel_1 	  	= $('#user_tel_1').val();
                    var user_email_1 	= $('#user_email_1').val();
                    var text_comment_1 	= $('#text_comment_1').val();
                    var user_country_1 	= $('#user_country_1').val();
                    if (!user_fio_1.length || !user_tel_1.length || !user_email_1.length) {
                        alert('Заполните, пожалуйста, все поля');
                        return;
                    }

                    if (!isValidEmailAddress(user_email_1)) {
                        alert('E-mail введен некорректно');
                        return;
                    }

                    window_hide_permanent_order();
                    window_barracuda_limited_010_order();
                    $.ajax({
                        url: "../sendmail.php",
                        type: "post",
                        dataType: "json",
                        data: {
                            "user_fio_1": 		user_fio_1,
                            "user_tel_1": 		user_tel_1,
                            "user_email_1": 	user_email_1,
                            "text_comment_1": 	text_comment_1,
                            "user_country_1": 	user_country_1,
                            "lang": 'ru'
                        },
                        success: function(data){
                            if (data && data.type == 'ok') {
//                                $('#btn_submit_1').html(data.data);
                                $('#user_fio_1').val('');
                                $('#user_tel_1').val('');
                                $('#user_email_1').val('');
                                $('#text_comment_1').val('');
  if (typeof ym === 'function') {
            ym(51442609, 'reachGoal', 'order');
            console.log('Метрика: цель "order" отправлена');
        }
//                                setTimeout(function(){
//                                    $('#btn_submit_1').html('//');
//                                }, 3000);
                            }
                            else {
                                alert(data.data);
                            }
                        }
                    });
                });
            });
        </script>

        <br/>
        <div class="messages_1"></div>
        <br/>

        <label>Ваше ФИО:</label><br/>
        <input class="input" type="text" id="user_fio_1" value="" /><br/>

        <label>Ваш телефон:</label><br/>
        <input class="input" type="text" id="user_tel_1" value="" /><br/>


        <label>Город:</label><br/>
        <input class="input" type="text" id="user_country_1" value="" /><br/>

        <label>Ваш e-mail:</label><br/>
        <input class="input" type="text" id="user_email_1" value="" /><br/>

        <label>Текст сообщения:</label><br/>
