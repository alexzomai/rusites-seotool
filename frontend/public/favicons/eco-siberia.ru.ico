<script type="text/javascript">

function picShow(param) {
    var paramId = "#pic"+param;
    $(paramId).fadeIn('slow');

    for(i=1;i<5;i++){
        var paramFor = "#pic"+i;
    	if (param != i) { $(paramFor).fadeOut('slow'); }
    	}
}

$(document).ready(function() {
	$("ul.topmeny li a").click(function() {
	$("ul.topmeny li a").removeClass("actBull").addClass("bull");
	$(this).removeClass("bull").addClass("actBull");
	});
});





$('#topSlider').hide();
$('#topSlider').load( function() {
$('#loader').hide();
$('#topSlider').show();
} );





</script>

