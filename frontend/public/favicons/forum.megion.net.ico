        ajax_alp.onreadystatechange(alp_update);
        ajax_alp.send('ajax.php', 'do=alp'+(pageid?'&page='+pageid:'')+(fidnum?'&f='+fidnum:''));
        fetch_object('vB_page'+pageid).style.color = "#0002FF";
        fetch_object('vB_page'+pageid).style.border.width = "1px";
    }

    function alp_blogs(pageid,fidnum)
    {
        countDownTime = 120;
        countlocation=1;
        ajax_alp = new vB_AJAX_Handler(true);
        ajax_alp.onreadystatechange(alp_update);
        ajax_alp.send('ajax.php', 'do=blogs'+(pageid?'&page='+pageid:'')+(fidnum?'&f='+fidnum:''));
    }

    function alp_change2()
    {
        countDownTime = 120;
        countlocation=2;
        ajax_alp = new vB_AJAX_Handler(true);
        ajax_alp.onreadystatechange(alp_update);
        ajax_alp.send('ajax.php', 'do=alp2');
    }

    function alp_post(postid,ev_obj,tip,catt)
    {
        countDownTime = 120;
        countlocation=2;
        if (ev_obj.target)
        {
                if (ev_obj.target.nodeName && ev_obj.target.nodeName=='SPAN')
                {
        //            fetch_object('alpbitsfree').innerHTML = '';
                }
        }
        ajax_alp = new vB_AJAX_Handler(true);
        ajax_alp.onreadystatechange(alp_update2);
        if (catt == 'forum') { ajax_alp.send('ajax.php', 'do=alp3&catt=forum&id='+ PHP.urlencode(postid)); 
        }
        if (catt == 'blog') { ajax_alp.send('ajax.php', 'do=alp3&catt=blog&id='+ PHP.urlencode(postid)); 
        }

        var pos_X = 0, pos_Y = 0;
        pos_X = ev_obj.clientX; 
        pos_Y = ev_obj.clientY;
        fetch_object('alpbitsfree').style.width = 800;
//      fetch_object('alpbitsfree').style.height = 200;
        if (ev_obj.target)
        {
           if (ev_obj.target.nodeName=='SPAN')
           {
              fetch_object('alpbitsfree').style.top = pos_Y+10+"px";
              fetch_object('alpbitsfree').style.left = pos_X-120+"px";
           }
        } else {
        if (tip == 'S') 
        {
              fetch_object('alpbitsfree').style.top = pos_Y+10+"px";
              fetch_object('alpbitsfree').style.left = pos_X-120+"px";
         }}

        fetch_object('alpbitsfree').style.visibility = 'visible';
    }

    function closeabf()
    {
        fetch_object('alpbitsfree').style.width = "800px";
        fetch_object('alpbitsfree').style.left = "-1200px";
        fetch_object('alpbitsfree').style.visibility = 'hidden';
        fetch_object('alpbitsfree').innerHTML = '';
    }

    function alp_update()
    {
        fetch_object('alpbits').innerHTML = '<center><img  src="images/ca_evo2/misc\/progress.gif" alt="" \/><b> Updating Alp Pro... <\/b><img  src="images/ca_evo2/misc\/progress.gif" alt="" \/><\/center>';
        if (ajax_alp.handler.readyState == 4 && ajax_alp.handler.status == 200 && ajax_alp.handler.responseText)
        {
            fetch_object('alp').innerHTML = ajax_alp.handler.responseText;
        }
    }

    function alp_update2()
    {
        if (ajax_alp.handler.readyState == 4 && ajax_alp.handler.status == 200 && ajax_alp.handler.responseText)
        {
            fetch_object('alpbitsfree').innerHTML = ajax_alp.handler.responseText;
        }
    }

//-->
</script>


