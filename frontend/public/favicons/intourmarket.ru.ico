<script language="javascript">
	var flag_click_call_name = false;
    var flag_click_call_phone_empty = false;
    var flag_click_call_phone_unlength = false;
</script>
<div class="w-popup" id="w-call">
  <div id="w-call-close"></div>
  <div class="hdr-plate">ЗАКАЗ ЗВОНКА</div>
  <p>Заполните форму и наш менеджер свяжется с Вами в течение дня!</p>
  <p class="snote">Внимание! Поля со звездочками обязательны для заполнения!</p>
  <form action="/order-call/" name="fm_call" id="fm-call" method="post" onsubmit="return validate_call();">
    <input type="hidden" name="action" value="send" >
    <input type="hidden" name="call" value="1" >
    <input type="hidden" name="url_back" value="/favicon.ico/" >
    <input type="hidden" name="name_mandatory" value="1" >
    <input type="hidden" name="phone_mandatory" value="1" >
    <input type="hidden" name="form_check_code" id="form_check_code_call_block" value="">
    <table>
      <tr>
        <td>Ваше&nbsp;имя:&nbsp;<span class="red">*</span></td>
        <td>
          <input type="text" name="name" id="fld-call-name" onclick="if(flag_click_call_name) {document.forms.fm_call.name.value='';document.forms.fm_call.name.style.backgroundColor='#FFFFFF';document.forms.fm_call.name.style.color='#333';flag_click_call_name=false;}" style="width:250px;" >
        </td>
      </tr>
      <tr>
        <td>Ваш&nbsp;телефон:&nbsp;<span class="red">*</span></td>
        <td>
          <input type="text" name="phone" id="fld-call-phone" onclick="if(flag_click_call_phone_empty || flag_click_call_phone_unlength) {document.forms.fm_call.phone.value='';document.forms.fm_call.phone.style.backgroundColor='#FFFFFF';document.forms.fm_call.phone.style.color='#333';flag_click_call_phone_empty=false;flag_click_call_phone_unlength=false;}" style="width:250px;" >
        </td>
      </tr>
      <tr>
        <td>Ваше&nbsp;сообщение:</td>
        <td>
          <textarea name="comment" id="fld-call-comment" rows="5" style="width:250px;"></textarea>
        </td>
      </tr>
    </table>
	<div align="center"><input type="submit" name="btn-call" id="btn-call" value="Заказать" class="button" ></div>
  </form>
</div>
<script language="javascript">
	var flag_click_tour_name = false;
    var flag_click_tour_phone_empty = false;
    var flag_click_tour_phone_unlength = false;
    var flag_click_tour_email_uncorrect = false;
</script>
<div class="w-popup" id="w-tour">
  <div id="w-tour-close"></div>
  <div class="hdr-plate">ЗАКАЗ ТУРА</div>
  <p>Заполните форму и наш менеджер свяжется с Вами в течение дня!</p>
  <p class="snote">Внимание! Поля со звездочками обязательны для заполнения!</p>
  <form action="/order-tour/" name="fm_tour" id="fm-tour" method="post" onsubmit="return validate_tour();">
    <input type="hidden" name="action" value="send" >
    <input type="hidden" name="url_back" value="/favicon.ico/" >
    <input type="hidden" name="name_mandatory" value="1" >
    <input type="hidden" name="phone_mandatory" value="1" >
    <input type="hidden" name="form_check_code" id="form_check_code_tour_block" value="">
    <table>
      <tr>
        <td>Ваше&nbsp;имя:&nbsp;<span class="red">*</span></td>
        <td>
          <input type="text" name="name" id="fld-tour-name" onclick="if(flag_click_tour_name) {document.forms.fm_tour.name.value='';document.forms.fm_tour.name.style.backgroundColor='#FFFFFF';document.forms.fm_tour.name.style.color='#333';flag_click_tour_name=false;}" style="width:250px;" >
        </td>
      </tr>
      <tr>
        <td>Ваш&nbsp;телефон:&nbsp;<span class="red">*</span></td>
        <td>
          <input type="text" name="phone" id="fld-tour-phone" onclick="if(flag_click_tour_phone_empty || flag_click_tour_phone_unlength) {document.forms.fm_tour.phone.value='';document.forms.fm_tour.phone.style.backgroundColor='#FFFFFF';document.forms.fm_tour.phone.style.color='#333';flag_click_tour_phone_empty=false;flag_click_tour_phone_unlength=false;}" style="width:250px;" >
        </td>
      </tr>
      <tr>
        <td>Ваш&nbsp;e-mail:</td>
        <td>
          <input type="text" name="email" id="fld_tour_email" onclick="if(flag_click_tour_email_uncorrect) {document.forms.fm_tour.email.value='';document.forms.fm_tour.email.style.backgroundColor='#FFFFFF';document.forms.fm_tour.email.style.color='#333';flag_click_tour_email_uncorrect=false;}" style="width:250px;" >
        </td>
      </tr>
      <tr>
        <td>Ваше сообщение:</td>
        <td><textarea name="comment" id="fld-tour-comment" rows="5" style="width:250px;"></textarea></td>
      </tr>
    </table>
	<div align="center"><input type="submit" name="btn-tour" id="btn-tour" value="Заказать" class="button" ></div>
  </form>
</div>
	</body>
</html>