}

.sp-megamenu-parent > li:hover > a {
    background: #F3CB9A;
}

.sp-megamenu-parent > li > a {
    color: #252525;
}
.sp-megamenu-parent > li > a, .sp-megamenu-parent > li > span {
    display: inline-block;
    padding: 0 15px;
    line-height: 40px;
    font-size: 15px;
    margin: 0;
    text-transform: uppercase;
}

/*боковые модули конец*/

