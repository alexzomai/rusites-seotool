    font-size: 1.2rem;
    margin: 0 0 1.25rem 0;
    text-align: center;
    font-weight: 600;
}
.article-list .article .readmore {
    font-size: 0.7rem;
    text-align: center;
    text-transform: uppercase;
    background: #000;
    padding: 5px 0 5px 0;
