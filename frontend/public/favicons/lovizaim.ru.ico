    <div class="alert_up callback_up">
		<div class="alert_up__title">Обратный звонок</div>
		<form class="box" name="callbackForm">
			<div class="fieldset">
				<div class="row" ng-class="{'error' : isInvalid(callbackForm.firstName)}">
					<div class="col first" ng-class="{'error' : isInvalid(callbackForm.firstName)}">Имя <span class="marker-red">*</span></div>
					<div class="col" ng-class="{'error' : isInvalid(callbackForm.firstName)}">
						<input class="input" name="firstName"
							   ng-model="callback.firstName"
							   ng-required="true"
							   ng-pattern="/^[\u0410-\u044f]*$/">
					</div>
				</div>
                <div class="row" ng-if="isInvalid(callbackForm.firstName)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>Имя должно содержать только русские символы</p>
                    </div>
                </div>

				<div class="row" ng-class="{'error' : isInvalid(callbackForm.lastName)}">
					<div class="col first" ng-class="{'error' : isInvalid(callbackForm.lastName)}">Фамилия</div>
					<div class="col" ng-class="{'error' : isInvalid(callbackForm.lastName)}">
						<input class="input" name="lastName"
							   ng-model="callback.lastName"
							   ng-pattern="/^[\u0410-\u044f]*$/">
					</div>
				</div>
                <div class="row" ng-if="isInvalid(callbackForm.lastName)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>Фамилия должна содержать только русские символы</p>
                    </div>
                </div>

				<div class="row" ng-class="{'error' : (isInvalid(callbackForm.email) && isSameEmail(callback.email))}">
					<div class="col first" ng-class="{'error' : (isInvalid(callbackForm.email) && isSameEmail(callback.email))}">E-mail</div>
					<div class="col" ng-class="{'error' : (isInvalid(callbackForm.email) && isSameEmail(callback.email))}">
						<input type="email" class="input" name="email"
							   ng-model-options="{ updateOn: 'blur' }"
							   ng-model="callback.email"
							   ng-pattern="/^([\w-]+(?:\.[\w-]+)*)@((?:[\w-]+\.)*\w[\w-]{0,66})\.([a-z]{2,6}(?:\.[a-z]{2})?)$/i">
					</div>
				</div>
                <div class="row" ng-if="isInvalid(callbackForm.email)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>E-mail имеет неверный формат</p>
                    </div>
                </div>
                <div class="row" ng-if="isSameEmail(callback.email)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>E-mail неверный</p>
                    </div>
                </div>

				<div class="row" ng-class="{'error' : (isInvalid(callbackForm.phone) && isSamePhone(callback.phone))}">
					<div class="col first" ng-class="{'error' : (isInvalid(callbackForm.phone) && isSamePhone(callback.phone))}">Телефон <span class="marker-red">*</span></div>
					<div class="col" ng-class="{'error' : (isInvalid(callbackForm.phone) && isSamePhone(callback.phone))}">
						<input type="tel" class="input tel phonenumbermask_jsp" name="phone"
							   ng-model="callback.phone"
							   ng-required="true">
					</div>
				</div>
                <div class="row" ng-if="isInvalid(callbackForm.phone)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>Телефон неверный</p>
                    </div>
                </div>
                <div class="row" ng-if="isSamePhone(callback.phone)">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>Телефон неверный</p>
                    </div>
                </div>

				<div class="row" ng-class="{'error' : callbackCaptchaValid == false}">
					<div id="call-captcha" style="width: 304px; margin: 10px auto;"></div>
				</div>
                <div class="row" ng-if="callbackCaptchaValid == false">
                    <div class="col w100p info-red" style="width: 566px">
                        <p>Вы не прошли проверку</p>
                    </div>
                </div>
