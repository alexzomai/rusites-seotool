<script>
	function redirectOverview() {
		var d = new Date();
        ga ('send', 'event', 'lichnui', 'cabinet');
        if (typeof yaCounter33286090 !== 'undefined') {
            yaCounter33286090.reachGoal('lichkabinet');
        }
		window.location.replace('/main/client/overview.shtml?' + d.getTime());
	}
</script>
<script>
    // Ждем полной загрузки страницы
    document.addEventListener('DOMContentLoaded', function() {
        // Открываем окно через 0.5 секунды
        setTimeout(function() {
            // Создаем модальное окно
            const modalHTML = `
                <div id="loanModalLz" class="modal-overlay-lz">
                    <div class="modal-content-lz">
                        <button class="close-button-lz" onclick="closeLoanModalLz()">&times;</button>
                        <img src="smile.png" alt="Улыбка" class="modal-icon-lz">
                        <div class="modal-title-lz">
                            Выдача займов на сайте не осуществляется.<br>
                            Посмотрите предложения наших партнёров
                        </div>
                        <a href="https://viruchay.ru/?utm_source=loviz" target="_blank" class="modal-button-lz">
                            Перейти
                        </a>
                    </div>
                </div>
            `;
            
            // Добавляем модальное окно в конец body
            document.body.insertAdjacentHTML('beforeend', modalHTML);
            
            // Показываем модальное окно
            openLoanModalLz();
        }, 500); // 500ms = 0.5 секунды
    });

    // Функции для работы с модальным окном
    function openLoanModalLz() {
        const modal = document.getElementById('loanModalLz');
        const body = document.body;
        
        if (modal) {
            modal.style.display = 'flex';
            body.classList.add('modal-open-lz');
        }
    }

    function closeLoanModalLz() {
        const modal = document.getElementById('loanModalLz');
        const body = document.body;
        
        if (modal) {
            modal.style.display = 'none';
            body.classList.remove('modal-open-lz');
        }
    }
</script>
