    <!-- Встроенные скрипты -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var commentBaseTime = new Date();

            function formatTime(date) {
                var hours = date.getHours().toString().padStart(2, '0');
                var minutes = date.getMinutes().toString().padStart(2, '0');
                return hours + ':' + minutes;
            }

            document.querySelectorAll('.comment-time-display').forEach(function(element) {
                var offsetMinutes = parseInt(element.dataset.timeOffset || 0);
                var time = new Date(commentBaseTime.getTime() - (offsetMinutes * 60 * 1000));
                element.textContent = formatTime(time);
            });

            setTimeout(function () {
                var modal = document.querySelector('.modal');
                if (modal) {
                    modal.classList.add('modal__show');
                }
            }, 4000);

            var toggleButton = document.getElementById("toggleButton1");
            if (toggleButton) {
                toggleButton.addEventListener("click", function () {
                    var block1 = document.getElementById("block1");
                    var block2 = document.getElementById("block2");
                    if (block1 && block2) {
                        block1.style.display = "none";
                        block2.style.display = "block";
                        // ДОБАВЛЕНА СТРОКА: плавная прокрутка страницы в самый верх
                        window.scroll({ top: 0, left: 0, behavior: 'smooth' }); 
                    }
                });
            }
        });

        var commInited = false;
        var commentInterval;

        $(document).ready(function () {
            if (!commInited) {
                commInited = true;
                commentInterval = setInterval(function () {
                    var nextHiddenComment = $("#icomments_list tr:not(.visible):first");

                    if (nextHiddenComment.length) {
                        nextHiddenComment.addClass('visible');
                    } else {
                        clearInterval(commentInterval);
                    }
                }, 3000);
            }
        });
    </script>

    <!-- СКРИПТ АНИМАЦИИ БЬЮЩЕГОСЯ СЕРДЦА (для главной страницы) -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const heartImages = [
                '/images/heartMini.png',
                '/images/heart.png',
                '/images/bigheart.png',
                '/images/heart.png' // Добавляем обратно среднее сердце для более плавного цикла
            ];
            let currentHeartIndex = 0;
            const animatedHeartLogo = document.getElementById('animatedHeartLogo');

            if (animatedHeartLogo) { // Проверяем, что элемент существует
                function animateHeart() {
                    animatedHeartLogo.src = heartImages[currentHeartIndex];
                    currentHeartIndex = (currentHeartIndex + 1) % heartImages.length; // Цикл по изображениям
                }
                // ИЗМЕНЕНИЕ ЗДЕСЬ: 300ms на 500ms
                setInterval(animateHeart, 500); // 500ms = 0.5 секунды на каждый кадр
            }
        });
    </script>

