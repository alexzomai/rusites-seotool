<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="ru" lang="ru" dir="ltr">
<head>
	<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
	
	<title> </title>
	<link rel="stylesheet" href="/SkinFiles/qrz.ru//main.css" type="text/css" />
	<link rel="stylesheet" href="/SkinFiles/qrz.ru//mainLogin.css" type="text/css" />
	<link rel="shortcut icon" href="/SkinFiles/qrz.ru//favicon.ico" />
	<script language="javascript" src="//code.jquery.com/jquery-1.12.4.min.js"></script>
	<script language="javascript" src="/SkinFiles/qrz.ru//jquery.backstretch.js"></script>
	<script language="javascript" src="/SkinFiles/qrz.ru//cookie.js"></script>
	<script language="javascript" src="/SkinFiles/qrz.ru//scripts.js"></script>
	<meta http-equiv="x-dns-prefetch-control" content="off" />
	<meta name="msapplication-navbutton-color" content="#2b5c90"/>
	<meta name="msapplication-task" content="name=Проверить почту;action-uri=/?return=mailbox.wssp%3FMailbox%3DINBOX;icon-uri=http://mail.qrz.ru/static/img/mail.ico"/>
	<meta name="msapplication-task" content="name=Написать письмо;action-uri=/?return=Compose.wssp;icon-uri=http://mail.qrz.ru/static/img/create.ico"/>
	<meta name="msapplication-task" content="name=Настройки;action-uri=/?return=Settings.wssp;icon-uri=http://mail.qrz.ru/static/img/settings.ico"/>

	<script type="text/javascript">
		$(document).ready(function(){
			var now = new Date(); var num = Math.ceil((now.getMinutes()+1)/7);
			var background = 'mail_login_0'+num+'.jpg';
			$("body").backstretch('/SkinFiles/qrz.ru//' + background);
		})
	</script>
</head>
<body>

<!-- Main Table -->
<div class="wrapper">

<header class="header"><img src="/SkinFiles/qrz.ru//logo.png"></header>

<div class="main-block">
	
	
	<section class="main__section ie8-flbck">
		<form id="login-form" method="POST" action="/" name="fr1">
			<input type="hidden" name="Language" value="russian">
			<input id="domain" type="hidden" name="login" value="1">

			<fieldset class="main__fieldset">
				<label class="field-label">Логин
					<input type="text" class="field  _email-field" name="Username" id="login" maxlength="255" alt="Логин" value="">
					<div class="main__error"></div>
				</label>
				<label class="field-label">Пароль
					<input type="password" class="field " name="Password" maxlength="99" alt="Пароль" id="pass">
					<div class="main__error"></div>
				</label>
				<label class="remember-me">
					<input type="checkbox" title="Запомнить меня на этом компьютере" name="remember" id="remember" value="1" onclick="checked_mail_remember(this);" checked="checked">
					запомнить меня
				</label>
			</fieldset>
			<fieldset class="main__fieldset_submit">
				<button type="submit" class="login-submit">Войти</button>
				<a href="http://passport.qrz.ru/recoverypassword" class="forget-pass" title="Если Вы забыли пароль, но при регистрации указывали резервный e-mail, то пароль Вы можете востановить автоматически.">Забыли пароль?</a>
			</fieldset>
			
			
			
		</form>
	</section>
	<section class="main__section">
		<ul class="main__banner-list">
			<li class="main__banner">
				<span class="main__banner-icon main__banner-icon_antivir"></span>
				<span>Почта защищена Антивирусом и Антиспамом</span>
			</li>
			<li class="main__banner">
				<span class="main__banner-icon main__banner-icon_box"></span>
				<span>Безлимитный почтовый ящик для ваших писем</span>
			</li>
		</ul>

		<a href="http://passport.qrz.ru/"><button class="reg-submit">Регистрация</button></a>
	</section>
</div>
</div>
<!-- End Main Table -->

<footer class="qrzmail-footer">
	<div class="qrzmail-copyright">
		<a href="http://www.qrz.ru/help/category/mail" class="qrzmail-help qrzmail-link_blue">Помощь</a>
		<span>© QRZ.RU</span>
	</div>
	<div class="qrzmail-counters">
		<script type="text/javascript"><!--
	document.write("<a href='//www.liveinternet.ru/click' "+
			"target=_blank><img src='//counter.yadro.ru/hit?t14.3;r"+
			escape(document.referrer)+((typeof(screen)=="undefined")?"":
			";s"+screen.width+"*"+screen.height+"*"+(screen.colorDepth?
					screen.colorDepth:screen.pixelDepth))+";u"+escape(document.URL)+
			";"+Math.random()+
			"' alt='' title='LiveInternet: показано число просмотров за 24"+
			" часа, посетителей за 24 часа и за сегодня' "+
			"border='0' width='88' height='31'><\/a>")
	//--></script>
	</div>
</footer>

