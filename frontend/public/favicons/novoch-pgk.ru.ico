<style>
  /********************** Уменьшение вертикальных размеров виджета Госуслуги ****************************************************************/
  
  /* Для узких экранов (мобильные) – до 500px */
  @media (max-width: 500px) {
    #js-show-iframe-wrapper .bf-2 {
      --pos-banner-fluid-2__grid-template-rows: 200px auto !important; /* было 310px auto */
      --pos-banner-fluid-2__decor-padding: 15px 15px 0 15px !important; /* было 30px 30px 0 30px */
      --pos-banner-fluid-2__content-padding: 0 15px 15px 15px !important; /* было 0 30px 30px 30px */
      --pos-banner-fluid-2__slogan-font-size: 18px !important; /* было 20px */
      --pos-banner-fluid-2__slogan-line-height: 24px !important; /* было 32px */
      --pos-banner-fluid-2__logo-wrap-padding: 15px 20px 15px 25px !important; /* было 20px 30px 30px 40px */
    }
    /* Текст и кнопка */
    #js-show-iframe-wrapper .bf-2__text {
      font-size: 20px !important;
      line-height: 26px !important;
    }
    #js-show-iframe-wrapper .bf-2__text_small {
      font-size: 14px !important;
      line-height: 20px !important;
    }
    #js-show-iframe-wrapper .bf-2__btn-wrap .pos-banner-btn_2 {
      min-height: 44px !important; /* было 56px */
      font-size: 16px !important; /* было 18px */
      line-height: 20px !important; /* было 24px */
    }
  }

  /* Для средних экранов (планшеты) – от 501px до 800px */
  @media (min-width: 501px) and (max-width: 800px) {
    #js-show-iframe-wrapper .bf-2 {
      --pos-banner-fluid-2__decor-padding: 15px 15px 15px 0 !important; /* было 30px 30px 30px 0 */
      --pos-banner-fluid-2__content-padding: 15px !important; /* было 30px */
      --pos-banner-fluid-2__slogan-font-size: 18px !important; /* было 24px */
      --pos-banner-fluid-2__slogan-line-height: 24px !important; /* было 32px */
      --pos-banner-fluid-2__logo-wrap-padding: 15px 20px 15px 25px !important; /* было 30px 30px 24px 40px */
    }
    /* Текст и кнопка */
    #js-show-iframe-wrapper .bf-2__text {
      font-size: 20px !important;
      line-height: 26px !important;
    }
    #js-show-iframe-wrapper .bf-2__text_small {
      font-size: 14px !important;
      line-height: 20px !important;
    }
    #js-show-iframe-wrapper .bf-2__btn-wrap .pos-banner-btn_2 {
      min-height: 44px !important;
      font-size: 16px !important;
      line-height: 20px !important;
    }
  }

  /* Для широких экранов (десктопы) – от 801px */
  @media (min-width: 801px) {
    #js-show-iframe-wrapper .bf-2 {
      --pos-banner-fluid-2__decor-padding: 20px 20px 20px 0 !important; /* уменьшено с 30px */
      --pos-banner-fluid-2__content-padding: 20px !important; /* было 30px */
      --pos-banner-fluid-2__slogan-font-size: 20px !important; /* было 32px */
      --pos-banner-fluid-2__slogan-line-height: 30px !important; /* было 40px */
      --pos-banner-fluid-2__logo-wrap-padding: 20px 25px 20px 35px !important; /* уменьшено */
    }
    /* Текст и кнопка */
    #js-show-iframe-wrapper .bf-2__text {
      font-size: 24px !important;
      line-height: 28px !important;
    }
    #js-show-iframe-wrapper .bf-2__text_small {
      font-size: 16px !important;
      line-height: 22px !important;
    }
    #js-show-iframe-wrapper .bf-2__btn-wrap .pos-banner-btn_2 {
      min-height: 48px !important;
      font-size: 17px !important;
      line-height: 22px !important;
    }
  }
</style>



