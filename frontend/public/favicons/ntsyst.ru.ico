<style type="text/css">
   body {
    font-family: Arial, Helvetica, sans-serif; /* Рубленый шрифт текста */
    margin: 0; /* Обнуляем отступы браузера */
	text-align: justify; /* Выравнивание по ширине */
	background-color: #ffffcc; /* Цвет фона веб-страницы */
	}
	p.dline {
    line-height: 1.8; /* Расстояние между строками */
   }
	p {
    text-indent: 0; /* Обнуляем отступ первой строки*/
	line-height: 1.4; /* Расстояние между строками */
	}
   h1 {
    text-align: center; /* Название по центру*/
	font-size: 34px; /* Размер шрифта */
	font-variant: small-caps; /* Тип шрифта - прописные */
	font-weight: bold; /* Жирное начертание */
    margin: 5px; /* Убираем отступы */
    color: 	#000000; /* Цвет текста */
   }
    h2 {
    margin: 0; /* Убираем отступ */
	font-variant: small-caps; /* Тип шрифта - прописные */
	text-align: left; /*Выравнивание по левому краю*/
	}
	h3 {
    margin: 0; /* Убираем отступ */
	font-variant: small-caps; /* Тип шрифта - прописные */
	}
	h4 {
	text-align: right; /* Выравнивание по правому краю */
	margin: 20px; /* Убираем отступ */
	margin-top: 0; /* Отступ сверху */
	font-style: italic; /* Курсив */
	font-variant: small-caps; /* Тип шрифта - прописные */
	font-weight: bold; /* Жирное начертание */
	}
   #head { /* Верхний блок */
    background: #99ccff; /* Цвет фона */
    padding: 4px; /* Поля вокруг */
	line-height: 1; /* Расстояние между строками */
	margin-top: 0; /* Отступ сверху */
	}
   #menu { /* Левая колонка */
    float: left; /* Обтекание справа */
    border: 1px solid #ff6600; /* Параметры рамки вокруг */
    width: 200px; /* Ширина колонки */
    padding: 5px; /* Поля вокруг текста */
    margin: 10px 10px 20px 10px; /* Значения отступов */
	text-align: left; /* Выравнивание по левому краю */
	font-size: 18px; /* Размер шрифта */
	font-variant: small-caps; /* Тип шрифта - прописные */
	font-weight: bold; /* Жирный шрифта */
	font-variant: small-caps; /* Тип шрифта - прописные */
	background: #ffffff; /* Цвет фона */	
	}
			.colortext {
					color: red; /* Красный цвет выделения */

						}
	#menu div {
    padding: 2px; /* Поля вокруг ссылок */
   }
   #menu a { 
    display: block; /* Отображать ссылку как блок */
    padding: 2px; /* Поля вокруг ссылок */
    margin: 1px; /* Отступы вокруг */
    font-size: 0.9em; /* Размер текста */
    text-decoration: none; /* Убираем подчеркивание текста */
	}
   #menu a:hover { 
    background: #ffffcc; /* Цвет фона */
    border: 1px dashed #ff6600; /* Добавление рамки */
    margin: 0; /* Убираем поля */
   }
   #content { /* Правая колонка */
    margin: 10px 5px 5px 230px; /* Значения отступов */
    padding: 20px; /* Поля вокруг текста */
    background: #ffffcc; /* Цвет фона */
	}
	.line {
    border-bottom: 1px groove #ff6600; /* Линия между ссылками */
   }
   .zagruzka {
    font-weight: bold; /* Жирный шрифта */
	padding: 1px; /* Поля вокруг ссылок */
	margin: 0; /* Убираем поля */
	}
	.zagruzka a:link {
    display: block; /* Отображать ссылку как блок */
	background: #ffffff; /* Цвет фона */
	text-decoration: none; /* Убираем подчеркивание текста */
	border: 1px solid #ff6600; /* Параметры рамки */
	}
   .zagruzka a:hover { 
    background: #ffffff; /* Цвет фона */
    border: 1px dashed #0000ff; /* Добавление рамки */
	}
   .leftimg {
    float:left; /* Выравнивание по левому краю */
    margin: 7px 7px 7px 0; /* Отступы вокруг картинки */
   }
   .rightimg  {
    float: right; /* Выравнивание по правому краю  */ 
    margin: 7px 0 7px 7px; /* Отступы вокруг картинки */
   }
   ul {
    list-style: disc inside; /* Маркер в виде точки     внутри текстового поля  */
	padding: 0; /* Поля вокруг текста */
	}
	li {
    line-height: 1.6; /* Расстояние между строками */
	}
	ol {
    list-style-type: none; /* Маркер отсутствует  */
	list-style-image: none;
	list-style-position: inside; /* Маркер обтекается текстом */
	padding: 0; /* Поля вокруг текста */
	}
    #foot { /* Нижний блок */
    background: #99ccff; /* Цвет фона */
    padding: 1px; /* Поля вокруг текста */
    color: #000000; /* Цвет текста */
    font-style: italic; /* Курсив */
	font-weight: bold; /* Жирное начертание */
	font-variant: small-caps; /* Тип шрифта - прописные */
	}
