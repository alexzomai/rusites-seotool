												$('#tooltip_button_kharakteritiki').show(200);
												},
													function (){
														$('#tooltip_button_kharakteritiki').hide();
															}
																);
																	
																	});
																	$('a[href^="#"]').click( function () {
																	var target = $(this).attr('href');
																	$('html,body').animate({scrollTop:$(target).offset().top},800);
																	return false;
																	});
																	</script>
