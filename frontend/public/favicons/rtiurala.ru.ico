<script type="text/javascript">
	$('#map').each(function(){
		ymaps.ready(init);
		var map;

		function init(){     
			map = new ymaps.Map ("map", {
				center: [56.81985777, 60.66524350],
				zoom: 16
			});
			
			var office = new ymaps.Placemark([56.81985777, 60.66524350], 
			{ 
				content: 'РТИ-Урала, +7 (343) 34–222–85'
			},
			{
				preset: 'islands#dotIcon',
				iconColor: '#015ab9'
			});
	
			map.geoObjects.add(office);
			map.behaviors.disable('scrollZoom');
		}
	});
</script>

