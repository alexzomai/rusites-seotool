			<script language="JavaScript">
function switch_ns_new(elem,host,ip,ps)
{
	if (elem.checked==true)
	{
		if (ps=='p')
		{
			hostvalue='ns1.best-hosting.ru';
			hostip='85.192.32.6';
		}
		else
		{
			hostvalue='ns2.best-hosting.ru';
			hostip='213.248.61.57';
		}
		
		document.forms[elem.form.name].elements[host].value=hostvalue;
		document.forms[elem.form.name].elements[host].readOnly=true;
		document.forms[elem.form.name].elements[ip].value=hostip;
		document.forms[elem.form.name].elements[ip].readOnly=true;
	}
	else
	{
		document.forms[elem.form.name].elements[host].value='';
		document.forms[elem.form.name].elements[ip].value='';
		document.forms[elem.form.name].elements[host].readOnly=false;
		document.forms[elem.form.name].elements[ip].readOnly=false;
	}
	
}

function switch_ns(elem,phost,paddr,shost,saddr)
{
	if (elem.checked==true) {
		document.forms[elem.form.name].elements[phost].value='ns1.best-hosting.ru';
		document.forms[elem.form.name].elements[phost].readOnly=true;
		document.forms[elem.form.name].elements[paddr].value='85.192.32.6';
		document.forms[elem.form.name].elements[paddr].readOnly=true;
		document.forms[elem.form.name].elements[shost].value='ns2.best-hosting.ru';
		document.forms[elem.form.name].elements[shost].readOnly=true;
		document.forms[elem.form.name].elements[saddr].value='213.248.61.57';
		document.forms[elem.form.name].elements[saddr].readOnly=true;
	}
	else {
		document.forms[elem.form.name].elements[phost].value='';
		document.forms[elem.form.name].elements[paddr].value='';
		document.forms[elem.form.name].elements[shost].value='';
		document.forms[elem.form.name].elements[saddr].value='';
		
		document.forms[elem.form.name].elements[phost].readOnly=false;
		document.forms[elem.form.name].elements[paddr].readOnly=false;
		document.forms[elem.form.name].elements[shost].readOnly=false;
		document.forms[elem.form.name].elements[saddr].readOnly=false;
		
	}
	return false;
}


function ShowWnd(Wnd,Wnd_name,width,height) {
	Wnd_window=open(Wnd, Wnd_name, 'fullscreen=no,channelmode=no,toolbar=no,location=no,directories=no,status=no,menubar=no,scrollbars=yes,resizable=no,width='+width+',height='+height);
	Wnd_window.focus();
return(false);
}


function SelectAll(formname, checkname,elem)
{
	for (i = 0; i < document.forms[formname].elements.length; i++)
	{
		var item=document.forms[formname].elements[i];
		if (item.name == checkname)
		{
			item.checked = elem.checked;// == true) ? false : true;
		}
	}
}

function checkrus(formname,elem,checkname)
{
	if (document.forms[formname].elements[elem].value!='')
	{
		var res=true;
	
		var inValid = new RegExp("[^A-Za-z0-9-]");
		var s=document.forms[formname].elements[elem].value;
		ss = s.split("\r\n");
		
		for (i=0; i<ss.length && res; i++)
		{
			sss=ss[i].replace(/(^\s*)|(\s*$)/g, "");
			if (sss.length>0)
			{
				if (inValid.test(ss[i]) || ss[i].length<3)
					res=false;
			}
		}
		
		if (res)
		{
			if (checkname!='')
			{
				res=false;
				for (i = 0; i < document.forms[formname].elements.length && !res; i++)
					if (document.forms[formname].elements[i].name == checkname)
						res=document.forms[formname].elements[i].checked;
			}
			
			if (res) 
				document.forms[formname].submit();
			else
				window.alert("┬тхфшЄх чюэє фы  яЁютхЁъш");
				
		}
			
		else
		 	window.alert("┬тхфшЄх ъюЁЁхъЄэ√х шьхэр фюьхэр (ырЄшэёъшх сєът√, ЎшЇЁ√ ш '-', фышээр эх ьхэхх 3 ёшьтюыют).");
	}
	else
		window.alert("┬тхфшЄх шь  фюьхэр.");
}


function domainorder(serviceID,formname,imgsize,DomainName)
{
	switch (imgsize){
		case 78:
			ShowWnd("/whois_info.asp?d="+DomainName,"",600,600);
			break;
		case 104:
			break;
		case 58:
			document.forms[formname].ServiceID.value=serviceID;
			document.forms[formname].DomainName.value=DomainName;
			document.forms[formname].submit();
	}

}			
