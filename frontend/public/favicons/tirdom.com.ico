                            jQuery("#adv7price_to_input").text(price_to);
                        }
                    });

					jQuery("#adv7price_from_input1").change(function(){
						  var value1=jQuery("#adv7price_from_input1").val();
						  var value2=jQuery("#adv7price_to_input1").val();
