	<!--<script language="javascript" src="/admin/js/mootools.js"></script>-->
	<script>

		function DisplayObject(obj_name)
		{
			$(obj_name).style.display = 'block';
		}
		
		function HideObject(obj_name)
		{
			$(obj_name).style.display = 'none';
		}
	
		function DisplayWithCoords(obj_name, x_pos, y_pos)
		{
			$(obj_name).setPosition({x: x_pos, y: y_pos});
			DisplayObject(obj_name);
		}

		function sendGetForm()
		{
		//alert(ap_id);
			var rqGetForm = new Request({
					method: 'post',
					url: 'http://wintergift.ru/ajaxrecallclient.php',
					onSuccess: function(txt){
						$('div_recall_content').set('html', txt);
					},
			
					onFailure: function(){
						$('div_recall_content').set('html', '<div style="color:#ff0000;">Ошибка в запросе</span><br>');
					}
			});		
		
			rqGetForm.send('selector=getform');
			DisplayObject('div_recall');
		}

		function sendRecall(sid)
		{
		//alert(ap_id);
			var rqSendRecall = new Request({
					method: 'post',
					url: 'http://wintergift.ru/ajaxrecallclient.php',
					onSuccess: function(txt){
						$('div_recall_content').set('html', txt);
					},
			
					onFailure: function(){
						$('div_recall_content').set('html', '<div style="color:#ff0000;">Отправка запроса прошла неудачно, попробуйте немного позже</span><br>');
					}
			});		
		
			rqSendRecall.send($('form_recall'));
		}
	
	</script>

</head>


