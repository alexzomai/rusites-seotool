				<script type="text/javascript">
	(function(win, doc, go, undefined){
	var PasswordOpener = function() {
		this.init.apply(this, arguments);
	};

	PasswordOpener.prototype.init = function (el, popup, right) {
		this.element = el;
		this.template = "<span class='showpassword p_abs'><span>" + popup + "</span></span>";
		this.state = false;
		this.wrapper = doc.createElement('div');
		this.wrapper.innerHTML = this.template;
		this.wrapper.className = 'p_rel';

		var insAfter = function (after, ins) {
		if (after.nextSibling) {
			after.parentNode.insertBefore(ins, after.nextSibling);
		} else {
			after.parentNode.appendChild(ins);
		}
		};


		insAfter(this.element, this.wrapper);
		this.showButton = this.wrapper.firstChild;
		// if (right || right === 0) {
		//	 this.showButton.style.right = right + "20px";
		// }
		this.wrapper.insertBefore(this.element, this.showButton);
		listevent(this.showButton, 'click', function(e) {
		this.show();
		}, {self: this});
	};

	PasswordOpener.prototype.show = function () {
		var cls = "active";
		if (this.state === false) {
		this.state = true;
		this.showButton.className += " " + cls;
		try {
			this.element.type = 'text';
		} catch (e) {}
		} else {
		this.state = false;
		this.showButton.className = this.showButton.className.replace(new RegExp('(\\s|^)'+cls+'(\\s|$)'),' ').replace(/^\s+|\s+$/g, '')
		try {
			this.element.type = 'password';
		} catch (e) {}
		}

	}

	go.alias({
		pwdOpener: function(cfg) {
		var cfg = cfg || {};
		var popup = cfg.msg || "<img src='//pics.loveplanet.ru/css/3/imgstc/spacer.png' alt='Показывать символы' title='Показывать символы'>";
		return new PasswordOpener(this, popup, cfg.right);
		}
	});

	})(window, window.document, go());
</script>

