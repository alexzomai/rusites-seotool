<script>
	const tagContainer = go('#tag-container')[0] || null;
	if (tagContainer) {
		Controll.controllSearchTags(tagContainer, go('#tag-drop-down')[0], go('#tags-string')[0]);
	}

	const setting = {
		setup1: {
			slider: go('#range_age1'),
			width: 190,
			start: [parseInt("16") || 25, parseInt("30") || 35],
			range: { min: 18, max: 99 },
			index: ['bage', 'tage'],
			title: 'Возраст',
		},
		setup2: {
			slider: go('#range_age2'),
			width: 230,
			start: [parseInt("16") || 25, parseInt("30") || 35],
			range: { min: 18, max: 99 },
			index: ['bage', 'tage'],
			title: 'Возраст',
		},
		setup3: {
			slider: go('#range_weight'),
			width: 186,
			start: [parseInt("") || 45, parseInt("") || 65],
			range: { min: 40, max: 150 },
			index: ['weight_fr', 'weight_to'],
			title: 'Вес',
		},
		setup4: {
			slider: go('#range_height'),
			width: 186,
			start: [parseInt("") || 150, parseInt("") || 170],
			range: { min: 140, max: 220 },
			index: ['height_fr', 'height_to'],
			title: 'Рост',
		},
	};
	for (let setup in setting) {
		Controll.controllSlider(setting[setup]);
	}

	function ext_open(){
		go("#expsearch_form, #expsearch_close").display('block');
		go("#expsearch_open").display('none');
		var es = go().byname("expsearch")[0];
		if (es.value) es.disabled = false;
	}
	function ext_close(){
		go("#expsearch_open").display('block');
		go("#expsearch_close, #expsearch_form").display('none');
		go().byname("expsearch")[0].disabled = true;
	}

	;(function(){
		var ext_mass = [
			// {name:'Знание языков', value:'extblock20'},
			{name:'Знание языков', value:'extblock33'},
			{name:'Вес', value:'extblock10'},
			{name:'Рост', value:'extblock4'},
			{name:'Отношения', value:'extblock3'},
			{name:'Есть ли дети', value:'extblock2'},
			{name:'Образование', value:'extblock21'},
			{name:'С материальным положением', value:'extblock17'},
			{name:'Отношение к курению', value:'extblock15'},
			{name:'Отношение к алкоголю', value:'extblock16'},
			{name:'Со знаком Зодиака', value:'extblock8'},
			//{name:'Режим дня', value:'extblock9'},
			{name:'Телосложение', value:'extblock5'},
			{name:'С цветом глаз', value:'extblock6'},
			{name:'С волосами на голове', value:'extblock11'},
			{name:'На теле есть', value:'extblock14'},
			//{name:'Материальная поддержка', value:'extblock24'},
			{name:'Наличие автомобиля', value:'extblock18'},
			{name:'Есть домашние животные', value:'extblock32'},
			{name:'Спорт', value:'extblock1'},
			{name:'Жилищные условия', value:'extblock19'},
			// {name:'Ориентация', value:'extblock25'},
			// {name:'Знакомится как пара', value:'extblock22'},
			// {name:'Ищет пару', value:'extblock23'}
			// {name:'Роль в сексе', value:'extblock26'},
			// {name:'Нравится в сексе', value:'extblock27'},
			// {name:'Оральный секс', value:'extblock28'},
			// {name:'Групповой секс', value:'extblock29'},
			// {name:'БДСМ', value:'extblock30'},
			// {name:'Фетиш', value:'extblock31'}
		],

		ext_select = go('#ext_select1, #ext_select2, #ext_select3'),

		ext_select_option = function(th){
			var ext_value = "";
			ext_select.each(function(sel){
				var oval = this.value;
				if (oval != "0") ext_value += oval + "_";
				if (sel == this) return;
				this.options.length = 1;
				for (var i = 0; i < ext_mass.length; i++) {
					var f = 0;
					for (var v = 0; v < ext_select.length; v++) {
						if (ext_select[v].value == ext_mass[i].value) {
							f = 1; break;
						}
					}
					if (!f) {
						this.options[this.options.length] = new Option(ext_mass[i].name, ext_mass[i].value, false, (ext_mass[i].value == oval));
					}
				}
			}, th);

			var es = go().byname("expsearch")[0];
			es.disabled = !ext_value;
			es.value = ext_value;
			go("#ext_storage [name]").each(function(){
				this.disabled = true;
			});
		},

		ext_select_change = function(){
			var id = '#' + this.getAttribute("data-targid");
			go("#ext_storage").append(go(id + ' > *'));

			ext_select_option(this);

			if (this.value && this.value != "0") {
				go(id).append(go('#' + this.value));
				go('#'+this.value +' [name]').each(function(){
					this.disabled = false;
					Controll.controllRefrash();
				});
			}
		};

		var ext_value = go().byname("expsearch")[0].value;
		if (ext_value) {
			ext_value = ext_value.split("_");
			ext_open();
		} else {
			ext_close();
		}

		ext_select_option(null);

		for (var i = 0; i < ext_select.length; i++) {
			if (ext_value[i]) {
				ext_select[i].value = ext_value[i];
				ext_select_change.call(ext_select[i]);
			}
		}

		ext_select.bind('change', ext_select_change);
		xinput.init(go("#search_panel"));
	})();
</script>

</div>
