		link_scan: function(){
			var rst = "|"+this.rest.join("|")+"|",
			r = new RegExp("^"+location.protocol+"//"+location.hostname+".*/a-(\\w+)/.*$"),
			l = new RegExp("login-(.*?)(\/|$)");
			go("a").each(function(ref, ext){
				var mt = this.href.match(r), lk = this.href.match(l);
				if (ref = (lk && lk[1]) || ref) ref = "/referer-"+ref;

				if (mt && rst.indexOf("|"+mt[1]+"|") != -1){
