<script type="text/javascript">
;(function(w){
	if(typeof restricted != 'undefined') restricted.link_scan();
	if(typeof content != 'undefined') content.init(document);

	actions.register({
	
		like_delete: function(login) {
			go("#sitm_"+login).cstyle({opacity: 0.3});
			(new transfer(function(){
				go("#sitm_"+login).remove();
				scroller.refresh();
			})).send("/api/a-likes/login-"+login+"/likes-2");
		},
		like_stage: function(login,btn){
			btn = go(btn, this);
			go("[data-stage]", this).bind("click", function(){
				var stage = this.dataset.stage;
				btn.display('none');
				if (stage == 0) {
					btn.id('likes').display('block');
					return false;
				} else {
					if(stage == 2){
						btn.id('likes_no').display('block');
						for(var h in content.histelm) go("#sitm_"+login, content.histelm[h]).remove();
					} else {
						btn.id('likes_yes').display('block');
					}

					(new transfer(function(data){
						if(stage == 1 || stage == 3){
							if(data.usr_like == 1 || data.usr_like == 3){
								btn.display('none');
								btn.id('likes_mut').display('block');
							}
						}
					},function(data){
						btn.display('none');
						btn.id('likes').display('block');
						if (data.errno == 8) location.href = "/a-elite";
						if (data.errno == 15) content.process("/a-showpage/name-alert", "modal", "window", {msg: data.error});
					})).jssend('/api/a-likes?login='+login+'&likes='+this.dataset.stage);
					return false;
				}
			});
		},
		list_stage: function(login,fav_btn,blk_btn){
			var curr, lists = {
				fav: {stor: "favorlist", on: "/api/a-mapi/fav-", off: "/api/a-mapi/res-", btn: go(fav_btn, this)},
				blk: {stor: "blacklist", on: "/api/a-mapi/blk-", off: "/api/a-mapi/res-", btn: go(blk_btn, this)}
			},
			refresh = function(){
				var f = ((exchange.storage.get(lists.fav.stor) || []).indexOf(login) != -1);
				lists.fav.btn.id("favorlist_to").display(f? 'none' : '');
				lists.fav.btn.id("favorlist_in").display(f? '' : 'none');

				f = ((exchange.storage.get(lists.blk.stor) || []).indexOf(login) != -1);
				lists.blk.btn.id("blacklist_to").display(f? 'none' : '');
				lists.blk.btn.id("blacklist_in").display(f? '' : 'none');
			};
			go("[data-stage]", this).bind("click", function(){
				var stage = this.dataset.stage;
				if (stage == "fav") curr = lists.fav;
				if (stage == "blk") curr = lists.blk;
				if (curr) {
					var d = exchange.storage.get(curr.stor) || [], idx = d.indexOf(login), url;
					if (idx == -1) {
						d.push(login);
						url = curr.on;
					} else {
						d.splice(idx,1);
						url = curr.off;
					}
					(new transfer(function(){
						exchange.storage.set(curr.stor, d);
						refresh();
					})).send(url+login);
					return false;
				}
			});
			refresh();
		}
	});
	actions.process(document);

	set_showid_handlers();
	set_closeid_handlers();

	title_override(document);

	xinput.init();

	var loaded = [];
	w.scroller = body_scroll(document, {
		block: "#scroll_content",
		off: "non",
		onscroll: function(e){
			if (e.scrollTop + e.clientHeight >= e.scrollHeight - e.clientHeight) {
				var shift = go('#scroll_shift');
				if (!shift.length || !shift[0].value) return;

				var uri = shift[0].value.split(/\?|\/\?/)[0], num = uri.match(/\/p-([0-9]*)/)[1] || 0;
				if (num == 1) {
					loaded = [];
					for(let id of go("#scroll_content [data-id]").get("dataset").get("id")) {
						loaded.push(id);
					}
				}
				shift.remove();
				if (uri.indexOf("a-search")) {
					evproc.fb('page_view_search', {page_num: num});
				}

				content.process(uri+"/popup", 'col_center', 'scroll', null, null, null, function(){
					go("#scroll_content .empty").remove();
					for(let id of go("[data-id]", this).get("dataset").get("id")) {
						if (loaded.includes(id)) go("#"+id, this).remove();
						else loaded.push(id);
					}
					// xinput.init(this);
					actions.process(this);
				});
			}
		}
	});

	go([document,window]).bind('resize', function(){
		w.scroller.refresh();
	});

	go(document).bind("scroll", function(){
		if ((document.documentElement || document.body).scrollTop > 1950) go("#top-btn").removeClass("non");
		else go("#top-btn").addClass("non");
	});

	go("[data-gacat]").each(function(){
		go(this).bind("click", function(){
			evproc.ga(this.getAttribute("data-gacat"), this.getAttribute("data-gaact"));
		});
	});

	var ah = (getcookie("affiliate_hist") || "").split(";");
	if (ah.length) {
		if (!ah[ah.length -1]) ah.pop();
		if (ah.length) {
			var tm = (new Date()).getUnixtime(), lst = parseInt(ah[ah.length -1].split(",")[0]),
			stor = new storage(), etm = parseInt(stor.get("visit_status") || 0);
			if (etm != lst && tm - lst < 60*20) {
				evproc.fb("visit_status", {
					cookie_exist: (ah.length > 1),
					amp: (!!~location.search.search("from=amp"))
				});
				stor.set("visit_status", lst);
			}
		}
	}

	for (var s of [ ]) {
		evproc.fb('server_split', s);
	}
})(window);









</script>





