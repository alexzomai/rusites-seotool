<style type="text/css">
	@keyframes block_down {
		from {opacity:0;}
		to {opacity:1;}
	}
	.block_down_anim{
		animation-name:block_down;
		animation-duration:0.5s;
		animation-timing-function:ease-in;
	}
</style>

<script type="text/html" id="tmpl_gallery">
	<li class="dm_hover p_rel block_down_anim">
		<a class="blue_bm" href="/page/{{prof.login}}/frl-4">
			<div class="gallery_photo img_clr p_rel">
				<img src="{{f_foto gal_foto, 'm110_'}}" alt="{{name}}" onerror="img_error(this,3,'{{f_foto foto, 'm110_'}}');">
			</div>
			<!--drop_menu-->
			<div class="dm_pad pt5">
				<div class="dm_box top rds6">
					<div class="dm_box_gallery">
						<span class="to_els fbold blue_14">{{prof.name}}</span><span>&#044; {{prof.age}} {{fn_numend prof.age, "год", "года", "лет"}}</span><br>
						{{prof.city_n}}
						<!-- {{#gal_notice}}
							<div class="greeting_text mt11 word_wrap">{{fn_emoji gal_notice}}</div>
						{{/gal_notice}} -->
						{{#prof.blocks.meet}}
							<div class="greeting_text mt11 word_wrap">
								Ищу {{#m_bage}}от {{m_bage}}{{/m_bage}} {{#m_tage}}до {{m_tage}} {{fn_numend m_tage, "год", "года", "лет"}}{{/m_tage}}
							</div>
						{{/prof.blocks.meet}}
					</div>
				</div>
			</div>
			<!--/drop_menu-->
		</a>
	</li>
</script>

<script type="text/javascript">
	exchange.storage.bind("gallery", this, function(kv, nv, ov){
		var imgstat = "//pics.loveplanet.ru/css/3/imgstc",
		tmpl = new mustache(go("#tmpl_gallery")[0], {
			fn_emoji: function(d,msg){
				return emojiparse(
					'<img align="absmiddle" width="20" height="20" src="'+imgstat+'/emoji2/@1.png" alt="@2" onerror="img_error(this);" />',
					msg
				);
			},
			fn_numend: function(d,val,v1,v2,v3) {
				var x2 = val % 100, x3 = x2 % 10;
				if (x2 >= 10 && x2 <= 20) return v3;
				if (x3 == 1) return v1;
				if (x3 && x3 < 5) return v2;
				return v3;
			},
			f_foto: function(d,url,ps){
				return url? url.replace("@", ps).replace(/http:|https:/, "") : "";
			},
			f_sexend: function(d,m,w,s) { return ((s || d.sex) == 1)? m : w; }
		}),

		next = function(count){
			go('#gallery_area').prepend(tmpl.parse(nv));
			var item = go("#gallery_area").children();
			if (item.length > 10) go(item.pop()).remove();

			item.cstyle({"transform": "translateX(-105px)"});
			(new animation(
				{d: -105},
				{d: 0},
				function(out){
					item.cstyle({"transform": "translateX("+out.d+"px)"})
				}, function(){
					if (--count) next(count);
				}, this, 500
			)).start();
		};

		next(nv.gal_num? nv.gal_num : 1);
	});
</script>



